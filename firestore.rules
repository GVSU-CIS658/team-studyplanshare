rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can only read/write their own document
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Study plans are readable by any authenticated user
    // All writes go through Cloud Functions (backend enforces ownership)
    match /studyPlans/{planId} {
      allow read: if request.auth != null;
      allow write: if false;

      match /upvotes/{userId} {
        allow read: if request.auth != null;
        allow write: if false;
      }
    }

    // Saved plans are private to each user
    match /savedPlans/{saveId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow write: if false;
    }
  }
}
